#!/bin/bash
set -ex

cd $HOME
echo "init submodules..."
yadm submodule update --recursive --init

function configure_mirrors() {
    echo "Configuring aliyun mirrors..."
    sudo tee /etc/pacman.d/mirrorlist > /dev/null <<'EOF'
Server = https://mirrors.aliyun.com/archlinux/$repo/os/$arch
EOF
    sudo sed -i 's/#Color/Color/g' /etc/pacman.conf
    sudo pacman -Syyu --noconfirm
}

function install_yay() {
    if ! command -v yay > /dev/null 2>&1; then
        sudo pacman -S git base-devel

        echo "Installing yay..."
        rm -rf /tmp/yay && git clone --depth 1 https://aur.archlinux.org/yay.git /tmp/yay && cd /tmp/yay && makepkg -si --noconfirm
        cd $HOME
    fi
}

function install_packages() {
    echo "Installing from .Pacmanfile..."
    yay -S --needed --noconfirm - < $HOME/.Pacmanfile
}

function setup_node() {
    source /usr/share/nvm/init-nvm.sh

    echo "Installing Node.js LTS..."
    nvm install --lts
    nvm use --lts

    echo "Installing npm global dependencies..."
    npm install -g tree-sitter-cli
}

function bootstrap_neovim() {
    if command -v nvim > /dev/null 2>&1; then
        echo "Bootstrapping Neovim..."
        nvim --headless '+Lazy! sync' +qa
        nvim --headless '+MasonToolsInstall' +qa 2>/dev/null || true
        nvim --headless -c 'sleep 30' -c 'qa' 2>/dev/null || true
    fi
}

configure_mirrors
install_yay
install_packages
setup_node
bootstrap_neovim
